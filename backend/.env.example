NODE_ENV=development
PORT=8000

# Database (SQLite file path)
DATABASE_URL=./data/medicare_hub.sqlite

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — the browser origin that calls the API (Vite dev server runs on :3000)
CORS_ORIGIN=http://localhost:3000

# Public base URL of the app (used in verification links, Stripe redirects, etc.)
APP_BASE_URL=http://localhost:3000

# Redis (optional — used for carts in production; falls back to SQLite if unset)
REDIS_URL=

# Seed/test data — password for the demo accounts created by `npm run seed`
SEED_TEST_PASSWORD=LocalTestPass1!

# --- Transactional email (SMTP, e.g. Zoho) ---
# Leave SMTP_HOST blank to disable email (sends are skipped, never error).
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@yourdomain.com
SMTP_PASS=your-smtp-password-or-app-password
SMTP_FROM_EMAIL=no-reply@yourdomain.com
SMTP_FROM_NAME=MediCare Hub

# --- Stripe (card payments, test/sandbox or live) ---
# Leave STRIPE_SECRET_KEY blank to disable card payments.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=tzs

# --- Mobile-money / SMS gateways (optional; empty = local simulation) ---
SELCOM_API_KEY=
SELCOM_API_SECRET=
MPESA_API_KEY=
MPESA_API_SECRET=
AIRTEL_API_KEY=
AIRTEL_API_SECRET=
SMS_API_KEY=
